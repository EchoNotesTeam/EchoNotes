# Copy this file to .env and fill in the values before running docker-compose.
# Generate secrets with: openssl rand -hex 32

# Shared secret between the TypeScript API and the Go orchestrator.
# Must match on both services.
INTERNAL_TOKEN=change_me_to_32_byte_hex

# Secret used to sign JWT session cookies.
JWT_SECRET=change_me_to_another_32_byte_hex

# CORS allowed origin for the Vue frontend (dev default shown).
CORS_ORIGIN=http://localhost:5173

# Database connection (uses the docker-compose service name).
DATABASE_URL=postgres://echonotes:echonotes@postgres:5432/echonotes

# Redis connection (uses the docker-compose service name).
REDIS_URL=redis://redis:6379

# Internal URL for the Go orchestrator (used by the TypeScript API).
AI_BASE_URL=http://ai:8080

# Internal URL for the Python ML service (used by the Go orchestrator).
ML_BASE_URL=http://ml:8000

# Root directory for uploaded audio files and generated artifacts.
# Both services must mount the same volume at this path.
ARTIFACT_ROOT=/var/echonotes
