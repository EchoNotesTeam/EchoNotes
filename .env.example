# EchoNotes — root environment variables
#
# Copy this file to .env and fill in the secret values before running.
# The canonical variable list is defined in §10.3 of the design plan.
#
# Generate secrets:
#   PowerShell: [System.BitConverter]::ToString([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32)).Replace("-","").ToLower()
#   Linux/macOS: openssl rand -hex 32

# ── Shared secrets ───────────────────────────────────────────────────────────

# 32-byte hex secret shared between the TypeScript API and the Go Orchestrator.
# Must be identical on both services. Used in the X-Internal-Token header.
INTERNAL_TOKEN=change_me_to_a_32_byte_hex_secret

# HS256 secret used to sign JWT session cookies (httpOnly, 14-day expiry).
# Must be at least 32 characters. Keep separate from INTERNAL_TOKEN.
JWT_SECRET=change_me_to_another_32_byte_hex_secret

# ── Database ─────────────────────────────────────────────────────────────────

# PostgreSQL 16 connection string.
# Use the Docker service name (postgres) inside containers,
# localhost:5432 for scripts running on the host (migrations, seed).
DATABASE_URL=postgres://echonotes:echonotes@localhost:5432/echonotes

# ── Cache / queue ────────────────────────────────────────────────────────────

# Redis 7 connection string. Used by the Go asynq job queue.
REDIS_URL=redis://localhost:6379

# ── Service URLs ─────────────────────────────────────────────────────────────

# Internal URL of the Go AI Orchestrator (used by the TypeScript API).
# Inside Docker Compose this is http://ai:8080.
# For local dev with the Go service running directly: http://localhost:8080.
AI_BASE_URL=http://localhost:8080

# Internal URL of the Python ML Service (used by the Go Orchestrator).
# Inside Docker Compose this is http://ml:8000.
# For local dev with uvicorn running directly: http://localhost:8001.
ML_BASE_URL=http://localhost:8000

# ── Frontend ─────────────────────────────────────────────────────────────────

# Allowed CORS origin for the Vue 3 SPA. Change to your production domain.
CORS_ORIGIN=http://localhost:5173

# ── Storage ──────────────────────────────────────────────────────────────────

# Root directory for uploaded audio files and generated artifacts.
# Both the TypeScript API and the Go Orchestrator must have read/write access.
# Inside Docker this is a named volume mounted at /var/echonotes.
# For local development on Windows: C:/var/echonotes (forward slashes).
ARTIFACT_ROOT=/var/echonotes
